---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Parse the markdown file
// Note: the relative path starts from where the Astro build/dev server is running (usually web-astro/)
const evalFilePath = path.resolve('../docs/EVAL_RESULTS.md');
let runs = [];

if (fs.existsSync(evalFilePath)) {
  const content = fs.readFileSync(evalFilePath, 'utf-8');
  const lines = content.split('\n');
  
  let inTable = false;
  for (const line of lines) {
    const trimmed = line.trim();
    
    // Detect table start
    if (trimmed.startsWith('| Date') || trimmed.startsWith('|Date')) {
      inTable = true;
      continue;
    }
    
    // Skip alignment row
    if (inTable && trimmed.startsWith('|---')) {
      continue; 
    }
    
    // Parse data rows
    if (inTable && trimmed.startsWith('|')) {
      const cells = trimmed.split('|').map(cell => cell.trim());
      
      // Need at least 8 elements if there are 7 columns bounded by pipes
      if (cells.length >= 8) {
        runs.push({
          date: cells[1],
          sha: cells[2].replace(/`/g, ''),
          precision: cells[3],
          recall: cells[4],
          f1: cells[5],
          disagreement: cells[6],
          promptVersion: cells[7]
        });
      }
    }
  }
}

// Sort newest first
runs.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="TrustMesh | Evaluation Results">
  <div class="bg-public-bg min-h-screen text-public-text-primary font-sans w-full absolute inset-0 z-50 overflow-y-auto">
    
    <!-- Navigation -->
    <nav class="border-b border-public-border bg-public-bg/80 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 rounded bg-trust-green/20 border border-trust-green flex items-center justify-center">
            <svg class="w-5 h-5 text-trust-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
          <span class="font-bold text-lg tracking-tight">TrustMesh</span>
        </a>
        <div class="flex items-center gap-6 text-sm font-medium">
          <a href="/" class="text-public-text-secondary hover:text-public-text-primary transition-colors">Home</a>
          <a href="/eval" class="text-trust-green transition-colors">Evaluation Results</a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-16">
      
      <!-- Header -->
      <div class="mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-trust-green/10 border border-trust-green/20 text-trust-green text-xs font-semibold tracking-wide uppercase mb-6">
          Model Evaluation
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">Manipulation Detector Holdout</h1>
        <p class="text-xl text-public-text-secondary max-w-3xl mb-4">
          Continuous evaluation metrics for the TrustMesh Manipulation Detector.
        </p>
        
        <!-- Caveat Alert -->
        <div class="bg-[#1e1e1e] border-l-4 border-public-text-secondary p-4 rounded-r-md mt-6">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-public-text-secondary mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p class="text-sm text-public-text-secondary">
              <strong class="text-public-text-primary">Evaluation Scope:</strong> These results are measured strictly against an 8-scenario adversarial holdout set to detect regressions across prompt iterations and model updates. They are <strong>not</strong> a claim of generalization to novel, unseen scenarios in the wild.
            </p>
          </div>
        </div>
      </div>

      <!-- Results Table -->
      <div class="bg-public-bg-alt border border-public-border rounded-xl overflow-hidden shadow-2xl">
        {runs.length === 0 ? (
          <div class="p-12 text-center flex flex-col items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-public-border/50 flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-public-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <h3 class="text-lg font-semibold mb-2">No evaluation runs recorded yet</h3>
            <p class="text-public-text-secondary max-w-sm mx-auto">
              The first evaluation run will appear here automatically after the CI benchmark executes successfully.
            </p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
              <thead>
                <tr class="bg-public-bg/50 border-b border-public-border text-public-text-secondary">
                  <th class="px-6 py-4 font-semibold">Date (UTC)</th>
                  <th class="px-6 py-4 font-semibold">Git SHA</th>
                  <th class="px-6 py-4 font-semibold">Precision</th>
                  <th class="px-6 py-4 font-semibold">Recall</th>
                  <th class="px-6 py-4 font-semibold">F1 Score</th>
                  <th class="px-6 py-4 font-semibold">Disagreement</th>
                  <th class="px-6 py-4 font-semibold">Prompt Version</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-public-border">
                {runs.map((run, i) => (
                  <tr class="hover:bg-public-border/10 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-public-text-primary">
                      {run.date}
                      {i === 0 && <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-trust-green/10 text-trust-green border border-trust-green/20">Latest</span>}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <a href={`https://github.com/Meetpatel427/TrustMesh/commit/${run.sha}`} target="_blank" rel="noopener noreferrer" class="text-trust-green hover:underline font-mono">
                        {run.sha.substring(0, 7)}
                      </a>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-public-text-primary">{run.precision}</td>
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-public-text-primary">{run.recall}</td>
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-public-text-primary">{run.f1}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-public-text-secondary">{run.disagreement}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-public-text-secondary">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-public-border/30">
                        {run.promptVersion}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
      
    </main>
  </div>
</Layout>
