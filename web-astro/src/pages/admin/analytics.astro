---
import Layout from '../../layouts/Layout.astro';
import AdminAnalyticsWidgets from '../../components/AdminAnalyticsWidgets';
---

<Layout title="Analytics Dashboard">
  <main class="mx-auto max-w-5xl px-6 py-page">
    <header class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-semibold tracking-tight text-text-primary">Analytics Insights</h1>
        <p class="mt-1 text-xs text-text-secondary">Platform-wide metrics and tactical trends</p>
      </div>
      <a href="/admin" class="text-sm font-medium text-gold hover:text-gold-hover transition-colors">
        &larr; Back to Admin
      </a>
    </header>

    <section class="mb-6">
      <AdminAnalyticsWidgets client:load />
    </section>
  </main>
</Layout>
