---
import '../styles/global.css';
import Header from '../components/Header.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description = "TrustMesh — Cryptographic trust & tamper-evident audit layer for autonomous AI-to-AI agent negotiations." } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-surface-900 text-text-primary">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title ? `${title} · TrustMesh` : 'TrustMesh | Cryptographic Trust for AI Agents'} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0F172A" />
    <title>{title ? `${title} · TrustMesh` : 'TrustMesh | Cryptographic Trust for AI Agents'}</title>
  </head>
  <body class="min-h-screen">
    <Header />
    <slot />
  </body>
</html>
