# TrustMesh Environment Variables
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.

# ── AI Provider Keys ────────────────────────────────────────────────
# Required for live LLM negotiations (Phases 1+).
# LLM_PROVIDER_CHAIN specifies the fallback order.
# Leave empty to run in mock mode (no API calls needed).
LLM_PROVIDER_CHAIN=groq,gemini,openrouter,mock
GEMINI_API_KEY=
GROQ_API_KEY=
# Get a free API key at openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Application ─────────────────────────────────────────────────────
# When set to true, an example-based anchor is prepended to the manipulation
# detector prompt to encourage more calibrated confidence scores.
# ENABLE_CALIBRATION_ANCHOR=false
# APP_ENV=development
# APP_HOST=0.0.0.0
# APP_PORT=8000
# LOG_LEVEL=info
# CURRENT_PHASE=1 — Agent Logic
# APP_VERSION=0.2.0

# ── Database ────────────────────────────────────────────────────────
# Default: local SQLite file. For Docker, the compose file overrides this.
# DATABASE_URL=sqlite+aiosqlite:///./trustmesh.db

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend dev server.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Rate Limiting
RATE_LIMIT_SESSION_CREATE=20/hour
RATE_LIMIT_TURN=100/hour
RATE_LIMIT_FALLBACK=500/hour

# ── Alerting & Notifications ─────────────────────────────────────────
# Slack/Discord incoming webhook URL — tamper alerts are logged locally if unset, dispatched here if set
TAMPER_ALERT_WEBHOOK_URL=

